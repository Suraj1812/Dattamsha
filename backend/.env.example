APP_NAME=Dattamsha HR Intelligence API
ENVIRONMENT=dev
DATABASE_URL=sqlite:///./dattamsha.db
NUDGE_THRESHOLD_ATTRITION=0.65
NUDGE_THRESHOLD_BURNOUT=0.70
POLICY_DOC_PATH=./policies/policies.md
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:8080,http://127.0.0.1:8080
TRUSTED_HOSTS=*
DEFAULT_USER_ROLE=admin
REQUIRE_AUTHENTICATION=true
API_KEY_ROLE=admin
REQUIRE_API_KEY=false
API_KEY=change-me-in-production
AUTH_JWT_SECRET=change-this-auth-secret
AUTH_ACCESS_TOKEN_MINUTES=30
AUTH_REFRESH_TOKEN_DAYS=14
AUTH_JWT_ISSUER=dattamsha-api
AUTH_JWT_AUDIENCE=dattamsha-clients
AUTH_ALLOW_SELF_SIGNUP=false
BOOTSTRAP_ADMIN_EMAIL=admin@dattamsha.local
BOOTSTRAP_ADMIN_FULL_NAME=Platform Admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe@123
ENFORCE_NUDGE_CONSENT=false
RATE_LIMIT_PER_MINUTE=120
ENABLE_DOCS=true
AUTO_CREATE_SCHEMA=true
RESPONSE_COMPRESSION_MIN_SIZE=1024
SNAPSHOT_REFRESH_BATCH_SIZE=5000
NUDGE_GENERATION_BATCH_SIZE=10000
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800
